#!/bin/sh
set -eu

# OpenHarness — local development harness for Claude Code and Codex
# CLI is the only state mutation entrypoint.

OPENHARNESS_ROOT="$(cd "$(dirname "$0")/.." && pwd)"

# shellcheck source=lib/install.sh
. "$OPENHARNESS_ROOT/lib/install.sh"
# shellcheck source=lib/init.sh
. "$OPENHARNESS_ROOT/lib/init.sh"
# shellcheck source=lib/task.sh
. "$OPENHARNESS_ROOT/lib/task.sh"
# shellcheck source=lib/worktree.sh
. "$OPENHARNESS_ROOT/lib/worktree.sh"
# shellcheck source=lib/delivery.sh
. "$OPENHARNESS_ROOT/lib/delivery.sh"
# shellcheck source=lib/interactive.sh
. "$OPENHARNESS_ROOT/lib/interactive.sh"
# shellcheck source=lib/maintain.sh
. "$OPENHARNESS_ROOT/lib/maintain.sh"

usage() {
  cat <<'EOF'
Usage: openharness <command> [args]

Commands:
  install <platform>    Install global assets (claude-code | codex)
  init                  Initialize current repo for OpenHarness
  start-task "<goal>"   Create a new task
  advance               Advance task state (intake->planning->implementing)
  status                Show active task state
  verify                Run verification and record evidence
  handoff               Produce final handoff summary
  interactive-verify    Interactive browser-based verification (start|complete)
  worktree [sub]        Manage git worktree (create|remove|status)
  maintain              Scan tasks for stale/blocked items
  gc [--purge]          Clean up worktrees for terminal tasks
  cleanup               Run cleanup commands (lint, format)
  commit                Auto-commit with generated message
  pr                    Create PR or draft from task

Options:
  --help, -h            Show this help
  --version             Show version
EOF
}

version() {
  echo "openharness 0.2.0"
}

case "${1:-}" in
  install)
    shift
    oh_install "$@"
    ;;
  init)
    shift
    oh_init "$@"
    ;;
  start-task)
    shift
    oh_start_task "$@"
    ;;
  advance)
    shift
    oh_advance "$@"
    ;;
  status)
    shift
    oh_status "$@"
    ;;
  verify)
    shift
    oh_verify "$@"
    ;;
  handoff)
    shift
    oh_handoff "$@"
    ;;
  interactive-verify)
    shift
    oh_interactive_verify "$@"
    ;;
  worktree)
    shift
    oh_worktree "$@"
    ;;
  maintain)
    shift
    oh_maintain "$@"
    ;;
  gc)
    shift
    oh_gc "$@"
    ;;
  cleanup)
    shift
    oh_cleanup "$@"
    ;;
  commit)
    shift
    oh_commit "$@"
    ;;
  pr)
    shift
    oh_pr "$@"
    ;;
  --version|-v)
    version
    ;;
  --help|-h|"")
    usage
    ;;
  *)
    echo "openharness: unknown command '$1'" >&2
    usage >&2
    exit 1
    ;;
esac
