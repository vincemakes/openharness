#!/bin/sh
# OpenHarness PreToolUse hook
# Blocks Edit/Write operations when active task is in intake or planning state.
# Exit 0 = allow, Exit 2 = block (stderr shown to agent as reason).

set -eu

INPUT="$(cat)"

# Extract tool name — lightweight JSON parsing without jq
TOOL_NAME="$(echo "$INPUT" | sed -n 's/.*"tool_name"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -1)"

# Only gate Edit and Write tools
case "$TOOL_NAME" in
  Edit|Write|NotebookEdit) ;;
  *) exit 0 ;;
esac

# Find repo root
REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || true)"
if [ -z "$REPO_ROOT" ]; then
  exit 0  # not in a git repo — passthrough
fi

# Check if OpenHarness is initialized
if [ ! -d "$REPO_ROOT/.openharness" ]; then
  exit 0  # not initialized — passthrough
fi

# Find active task
TASKS_DIR="$REPO_ROOT/.openharness/tasks"
if [ ! -d "$TASKS_DIR" ]; then
  exit 0  # no tasks dir — passthrough
fi

# Get the most recent task directory
ACTIVE_TASK="$(ls -1t "$TASKS_DIR" 2>/dev/null | head -1)"
if [ -z "$ACTIVE_TASK" ]; then
  exit 0  # no tasks — passthrough (no active task = no enforcement)
fi

STATUS_FILE="$TASKS_DIR/$ACTIVE_TASK/status.json"
if [ ! -f "$STATUS_FILE" ]; then
  exit 0
fi

# Read current status
STATUS="$(sed -n 's/.*"status"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$STATUS_FILE" | head -1)"

# Extract the file being edited
FILE_PATH="$(echo "$INPUT" | sed -n 's/.*"file_path"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -1)"

# Allow edits to openharness task artifacts (plan.md, task.md, etc.)
case "$FILE_PATH" in
  */.openharness/tasks/*) exit 0 ;;
  */.openharness/*) exit 0 ;;
esac

# Block writes during intake and planning
case "$STATUS" in
  intake)
    echo "OpenHarness: task '$ACTIVE_TASK' is in 'intake' state." >&2
    echo "Complete the task definition first, then write plan.md before implementing." >&2
    echo "Run: openharness status" >&2
    exit 2
    ;;
  planning)
    echo "OpenHarness: task '$ACTIVE_TASK' is in 'planning' state." >&2
    echo "Complete plan.md before writing implementation code." >&2
    echo "Once plan.md is ready, update status to 'implementing' via the plan transition." >&2
    echo "Run: openharness status" >&2
    exit 2
    ;;
esac

# All other states (implementing, verifying, fixing) — allow writes
exit 0
